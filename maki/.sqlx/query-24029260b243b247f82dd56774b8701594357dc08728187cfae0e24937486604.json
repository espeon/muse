  "query": "\n        SELECT users.id, users.name, users.email, users.image, users.is_admin,\n               EXISTS (\n                   SELECT 1 FROM user_lastfm WHERE user_lastfm.\"userId\" = users.id\n               ) AS \"lastfm_connected!: bool\"\n        FROM users\n        WHERE users.id = $1\n        ",
