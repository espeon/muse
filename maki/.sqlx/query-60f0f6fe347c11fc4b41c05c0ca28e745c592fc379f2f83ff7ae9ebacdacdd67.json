{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT artist.id, artist.slug, artist.name, artist.picture, COUNT(album.id) AS num_albums\n        FROM artist\n        LEFT JOIN album ON artist.id = album.artist\n        WHERE artist.id IN (SELECT artist FROM song_artist WHERE song = ANY($1))\n        GROUP BY artist.id\n        ",
