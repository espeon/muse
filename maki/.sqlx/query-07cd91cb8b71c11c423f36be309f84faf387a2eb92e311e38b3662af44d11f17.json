  "query": "\n        UPDATE playlist\n        SET name        = COALESCE($3, name),\n            description = COALESCE($4, description),\n            updated_at  = now()\n        WHERE id = $1 AND user_id = $2\n        RETURNING id, name, description, art_path, created_at, updated_at\n        ",
