{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.id, p.name, p.description, p.art_path, p.created_at, p.updated_at,\n               COUNT(pi.id) AS track_count\n        FROM playlist p\n        LEFT JOIN playlist_item pi ON p.id = pi.playlist_id\n        WHERE p.user_id = $1\n        GROUP BY p.id\n        ORDER BY p.created_at DESC\n        ",
