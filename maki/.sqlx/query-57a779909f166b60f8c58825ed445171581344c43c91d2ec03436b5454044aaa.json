  "query": "\n        SELECT path, number, song.name, album.name as album_name, duration, artist.name as artist_name\n        FROM song\n        LEFT JOIN album ON song.album = album.id\n        LEFT JOIN artist ON song.album_artist = artist.id\n        WHERE song.id = $1\n        ",
