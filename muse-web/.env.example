# When muse-web is embedded into maki (the default), the SPA is same-origin
# with the API and VITE_MAKI_URL is not needed. Only set it for standalone
# dev mode (e.g. `vite dev` against a remote maki instance).
# VITE_MAKI_URL=http://localhost:3033

# umi — optional lyrics service. Frontend fails silently without it.
VITE_UMI_URL=http://localhost:3032
